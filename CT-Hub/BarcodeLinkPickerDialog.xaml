<Window x:Class="CTHub.BarcodeLinkPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Link — Pick a Row"
        Width="540" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="#252526"
        Foreground="#D4D4D4">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Search + filter -->
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Search rows to link" Foreground="#858585" FontSize="11" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Background="#1E1E1E" Foreground="#D4D4D4"
                         BorderBrush="#3C3C3C" BorderThickness="1"
                         FontFamily="Consolas" FontSize="13"
                         Padding="8,5"
                         TextChanged="SearchBox_TextChanged"/>
                <ComboBox x:Name="TableFilter"
                          Grid.Column="1"
                          Width="140" Margin="8,0,0,0"
                          SelectionChanged="TableFilter_SelectionChanged"/>
            </Grid>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="LinkButton"
                    Style="{StaticResource ActionButton}"
                    Content="Link Selected"
                    IsEnabled="False"
                    Click="Link_Click"
                    Margin="0,0,8,0"/>
            <Button Style="{StaticResource ActionButton}"
                    Content="Cancel"
                    IsCancel="True"/>
        </StackPanel>

        <!-- Results list -->
        <Border BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="4" Background="#1E1E1E">
            <ListBox x:Name="ResultsList"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#D4D4D4"
                     FontFamily="Consolas"
                     FontSize="13"
                     SelectionChanged="ResultsList_SelectionChanged"
                     MouseDoubleClick="ResultsList_DoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="#007ACC" CornerRadius="3"
                                    Padding="5,2" Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding TableBadge}"
                                           Foreground="White" FontSize="10"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}" FontSize="13"/>
                                <TextBlock Text="{Binding SubLabel}" Foreground="#666" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="4,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

    </DockPanel>
</Window>
