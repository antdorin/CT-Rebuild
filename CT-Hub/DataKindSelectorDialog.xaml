<Window x:Class="CTHub.DataKindSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Column Setup"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="#252526"
        Foreground="#D4D4D4">

    <Window.Resources>
        <!-- Kind button style — toggles selection via IsChecked -->
        <Style x:Key="KindButton" TargetType="ToggleButton">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                                <Setter Property="BorderBrush" Value="#1C97EA"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#9CDCFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#858585"/>
            <Setter Property="Margin" Value="4,8,4,2"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OkButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1C97EA"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Header name input -->
        <TextBlock Text="Column Name" Foreground="#858585" FontSize="11" Margin="0,0,0,4"/>
        <TextBox x:Name="HeaderTextBox"
                 Background="#1E1E1E" Foreground="#D4D4D4"
                 BorderBrush="#3F3F46" BorderThickness="1"
                 Padding="6,4" FontSize="13"
                 Margin="0,0,0,12"/>

        <!-- Data Types group -->
        <TextBlock Text="Data Type" Style="{StaticResource SectionLabel}"/>
        <WrapPanel x:Name="DataTypePanel" Margin="0,0,0,4">
            <ToggleButton x:Name="KindText"       Content="📝 Text"       Tag="Text"        Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindNumber"     Content="🔢 Number"     Tag="Number"      Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindDropdown"   Content="📋 Dropdown"   Tag="Dropdown"    Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindDate"       Content="📅 Date"       Tag="Date"        Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindToggle"     Content="🔘 Toggle"     Tag="Toggle"      Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindComputed"   Content="∑ Computed"    Tag="Computed"    Style="{StaticResource KindButton}" Click="KindButton_Click"/>
        </WrapPanel>

        <!-- Android Actions group -->
        <TextBlock Text="Android Action" Style="{StaticResource SectionLabel}"/>
        <WrapPanel Margin="0,0,0,4">
            <ToggleButton x:Name="KindBarcode"    Content="📷 Barcode Scan" Tag="BarcodeScan"  Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindPhoto"      Content="🖼 Photo"        Tag="Photo"        Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindGps"        Content="📍 GPS"          Tag="Gps"          Style="{StaticResource KindButton}" Click="KindButton_Click"/>
            <ToggleButton x:Name="KindManual"     Content="✏️ Manual Entry" Tag="ManualEntry"  Style="{StaticResource KindButton}" Click="KindButton_Click"/>
        </WrapPanel>

        <!-- Dropdown options (visible only when Dropdown is selected) -->
        <StackPanel x:Name="DropdownOptionsPanel" Visibility="Collapsed" Margin="0,4,0,4">
            <TextBlock Text="Options (comma-separated)" Foreground="#858585" FontSize="11" Margin="0,0,0,4"/>
            <TextBox x:Name="DropdownOptionsBox"
                     Background="#1E1E1E" Foreground="#D4D4D4"
                     BorderBrush="#3F3F46" BorderThickness="1"
                     Padding="6,4" FontSize="12"
                     ToolTip="e.g. Option A, Option B, Option C"/>
        </StackPanel>

        <!-- Computed formula (visible only when Computed is selected) -->
        <StackPanel x:Name="ComputedFormulaPanel" Visibility="Collapsed" Margin="0,4,0,4">
            <TextBlock Text="Column A" Foreground="#858585" FontSize="11" Margin="0,0,0,4"/>
            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="+" Width="18" TextAlignment="Center" VerticalAlignment="Center"
                           Foreground="#CE9178" FontWeight="Bold" DockPanel.Dock="Left" Margin="0,0,6,0"/>
                <TextBox x:Name="FormulaMultiplier1" Width="56" DockPanel.Dock="Right"
                         Background="#1E1E1E" Foreground="#CE9178"
                         BorderBrush="#3F3F46" BorderThickness="1"
                         Padding="6,4" FontSize="12" Text="1"
                         ToolTip="Multiplier: 1 unit of this column equals this amount"/>
                <TextBlock Text="×" Width="20" TextAlignment="Center" VerticalAlignment="Center"
                           Foreground="#858585" DockPanel.Dock="Right" Margin="4,0,4,0"/>
                <ComboBox x:Name="FormulaCol1"
                          Background="#1E1E1E" Foreground="#303030"
                          BorderBrush="#3F3F46" BorderThickness="1"
                          Padding="6,4" FontSize="12"/>
            </DockPanel>
            <TextBlock Text="Column B" Foreground="#858585" FontSize="11" Margin="0,0,0,4"/>
            <DockPanel>
                <ComboBox x:Name="FormulaSign2"
                          Width="52" DockPanel.Dock="Left"
                          Background="#1E1E1E" Foreground="#CE9178"
                          BorderBrush="#3F3F46" BorderThickness="1"
                          Padding="6,4" FontSize="12" Margin="0,0,6,0"/>
                <TextBox x:Name="FormulaMultiplier2" Width="56" DockPanel.Dock="Right"
                         Background="#1E1E1E" Foreground="#CE9178"
                         BorderBrush="#3F3F46" BorderThickness="1"
                         Padding="6,4" FontSize="12" Text="1"
                         ToolTip="Multiplier: 1 unit of this column equals this amount"/>
                <TextBlock Text="×" Width="20" TextAlignment="Center" VerticalAlignment="Center"
                           Foreground="#858585" DockPanel.Dock="Right" Margin="4,0,4,0"/>
                <ComboBox x:Name="FormulaCol2"
                          Background="#1E1E1E" Foreground="#303030"
                          BorderBrush="#3F3F46" BorderThickness="1"
                          Padding="6,4" FontSize="12"/>
            </DockPanel>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource ActionButton}" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button x:Name="OkButton" Content="OK" Style="{StaticResource OkButton}" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
