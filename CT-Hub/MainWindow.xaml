<Window x:Class="CTHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CT Hub"
        Height="780" Width="1100"
        MinHeight="500" MinWidth="700"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Shared DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3C3C3C"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#5C1A1A"/>
            <Setter Property="BorderBrush" Value="#8B2020"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ── Status Bar ──────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#007ACC" Foreground="White"
                   FontFamily="Consolas" FontSize="12">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ClientCountText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding LastBroadcast}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Tab Control ─────────────────────────────────────────────────── -->
        <TabControl Background="#1E1E1E" BorderBrush="#3C3C3C"
                    Foreground="#D4D4D4">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#9CDCFE"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ── Chase Tactical ─────────────────────────────────────────── -->
            <TabItem Header="Chase Tactical">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526" Band="1">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ChaseTactical_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ChaseTactical_Delete"/>
                    </ToolBar>
                    <DataGrid x:Name="ChaseTacticalGrid"
                              ItemsSource="{Binding ChaseTacticalItems}"
                              CellEditEnding="ChaseTactical_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bin"         Binding="{Binding Bin}"         Width="120"/>
                            <DataGridTextColumn Header="Label"       Binding="{Binding Label}"       Width="200"/>
                            <DataGridTextColumn Header="Qty"         Binding="{Binding Qty}"         Width="80"/>
                            <DataGridTextColumn Header="Notes"       Binding="{Binding Notes}"       Width="*"/>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── Tough Hooks ───────────────────────────────────────────── -->
            <TabItem Header="Tough Hooks">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ToughHooks_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ToughHooks_Delete"/>
                    </ToolBar>
                    <DataGrid x:Name="ToughHooksGrid"
                              ItemsSource="{Binding ToughHookItems}"
                              CellEditEnding="ToughHooks_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bin"         Binding="{Binding Bin}"         Width="120"/>
                            <DataGridTextColumn Header="SKU"         Binding="{Binding Sku}"         Width="140"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Qty"         Binding="{Binding Qty}"         Width="80"/>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── QR Mappings ───────────────────────────────────────────── -->
            <TabItem Header="QR Mappings">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="QrMappings_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="QrMappings_Delete"/>
                    </ToolBar>
                    <DataGrid x:Name="QrMappingsGrid"
                              ItemsSource="{Binding QrMappingItems}"
                              CellEditEnding="QrMappings_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="QR Value"      Binding="{Binding QrValue}"      Width="220"/>
                            <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="180"/>
                            <DataGridTextColumn Header="Description"   Binding="{Binding Description}"  Width="*"/>
                            <DataGridTextColumn Header="ID"            Binding="{Binding Id}"            Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── PDF Folder ─────────────────────────────────────────────── -->
            <TabItem Header="PDF Folder">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="📂  Browse…"
                                Click="PdfFolder_Browse"/>
                        <Separator/>
                        <TextBlock x:Name="PdfFolderPathText"
                                   Text="No folder selected"
                                   Foreground="#9CDCFE"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                    </ToolBar>
                    <ListBox x:Name="PdfFileList"
                             Background="#252526"
                             Foreground="#D4D4D4"
                             BorderBrush="#3C3C3C"
                             BorderThickness="1"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="4"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
