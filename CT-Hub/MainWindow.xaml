<Window x:Class="CTHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CTHub"
        Title="CT Hub"
        Height="780" Width="1100"
        MinHeight="500" MinWidth="700"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Shared DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3C3C3C"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <EventSetter Event="ContextMenuOpening" Handler="ColumnHeader_ContextMenuOpening"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#5C1A1A"/>
            <Setter Property="BorderBrush" Value="#8B2020"/>
        </Style>
        <Style x:Key="PdfModeButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinWidth" Value="68"/>
        </Style>
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ── Status Bar ──────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#007ACC" Foreground="White"
                   FontFamily="Consolas" FontSize="12">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusTextDisplay}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ClientCountText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding LastBroadcast}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <CheckBox Content="Privacy Mode"
                          IsChecked="{Binding IsPrivacyModeOn, UpdateSourceTrigger=PropertyChanged}"
                          Foreground="White"
                          VerticalAlignment="Center"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Tab Control ─────────────────────────────────────────────────── -->
        <TabControl Background="#1E1E1E" BorderBrush="#3C3C3C"
                    Foreground="#D4D4D4">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#9CDCFE"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ── Chase Tactical ─────────────────────────────────────────── -->
            <TabItem Header="Chase Tactical">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526" Band="1">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ChaseTactical_Add"/>
                        <Button Style="{StaticResource ToolbarButton}"
                            Content="⇪  Import Bulk"
                            Click="ChaseTactical_ImportBulk"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ChaseTactical_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ChaseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search bin, label, qty, notes, id"/>
                    </Border>
                    <DataGrid x:Name="ChaseTacticalGrid"
                              ItemsSource="{Binding ChaseTacticalItems}"
                              CellEditEnding="ChaseTactical_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="ChaseTactical_Add"/>
                                <MenuItem Header="Import Bulk" Click="ChaseTactical_ImportBulk"/>
                                <MenuItem Header="Delete Selected" Click="ChaseTactical_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Bin"
                                                    SelectedItemBinding="{Binding Bin, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{x:Static local:MainWindow.BinLocations}"
                                                    Width="130"/>
                            <DataGridComboBoxColumn Header="Class"
                                                    SelectedItemBinding="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{x:Static local:MainWindow.ClassNames}"
                                                    Width="220"/>
                            <DataGridComboBoxColumn Header="Letter"
                                                    SelectedItemBinding="{Binding ClassLetter, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{x:Static local:MainWindow.ClassLetters}"
                                                    Width="80"/>
                            <DataGridTextColumn Header="Class ID"    Binding="{Binding ClassId}"     Width="180" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Label"       Binding="{Binding Label}"       Width="200"/>
                            <DataGridTextColumn Header="Qty"         Binding="{Binding Qty}"         Width="80"/>
                            <DataGridTextColumn Header="Notes"       Binding="{Binding Notes}"       Width="*"/>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── Tough Hooks ───────────────────────────────────────────── -->
            <TabItem Header="Tough Hooks">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ToughHooks_Add"/>
                        <Button Style="{StaticResource ToolbarButton}"
                            Content="⇪  Import Bulk"
                            Click="ToughHooks_ImportBulk"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ToughHooks_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ToughHooksSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search bin, sku, description, qty, id"/>
                    </Border>
                    <DataGrid x:Name="ToughHooksGrid"
                              ItemsSource="{Binding ToughHookItems}"
                              CellEditEnding="ToughHooks_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="ToughHooks_Add"/>
                                <MenuItem Header="Import Bulk" Click="ToughHooks_ImportBulk"/>
                                <MenuItem Header="Delete Selected" Click="ToughHooks_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bin"         Binding="{Binding Bin}"         Width="120"/>
                            <DataGridTextColumn Header="SKU"         Binding="{Binding Sku}"         Width="140"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Qty"         Binding="{Binding Qty}"         Width="80"/>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── QR Mappings ───────────────────────────────────────────── -->
            <TabItem Header="QR Mappings">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="QrMappings_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="QrMappings_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding QrMappingsSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search QR value, classification, description, id"/>
                    </Border>
                    <DataGrid x:Name="QrMappingsGrid"
                              ItemsSource="{Binding QrMappingItems}"
                              CellEditEnding="QrMappings_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="QrMappings_Add"/>
                                <MenuItem Header="Delete Selected" Click="QrMappings_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="QR Value"      Binding="{Binding QrValue}"      Width="220"/>
                            <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="180"/>
                            <DataGridTextColumn Header="Description"   Binding="{Binding Description}"  Width="*"/>
                            <DataGridTextColumn Header="ID"            Binding="{Binding Id}"            Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── Shipping Supplys ─────────────────────────────────────── -->
            <TabItem Header="Shipping Supplys">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ShippingSupplys_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ShippingSupplys_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ShippingSupplysSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search dimensions, bundle, single, id"/>
                    </Border>
                    <DataGrid x:Name="ShippingSupplysGrid"
                              ItemsSource="{Binding ShippingSupplysItems}"
                              CellEditEnding="ShippingSupplys_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="ShippingSupplys_Add"/>
                                <MenuItem Header="Delete Selected" Click="ShippingSupplys_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dimensions" Binding="{Binding Dimensions}" Width="*"/>
                            <DataGridTextColumn Header="Bundle"     Binding="{Binding Bundle}"     Width="120"/>
                            <DataGridTextColumn Header="Single"     Binding="{Binding Single}"     Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── PDF Folder ─────────────────────────────────────────────── -->
            <TabItem Header="PDF Folder">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="240" MinHeight="160"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ToolBar Grid.Row="0" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="📂  Browse…"
                                Click="PdfFolder_Browse"/>
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="⚖  Scale Selected…"
                                Click="PdfScale_Click"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="🗑  Delete Selected"
                                Click="PdfDelete_Click"/>
                        <Separator/>
                        <TextBlock x:Name="PdfFolderPathText"
                                   Text="No folder selected"
                                   Foreground="#9CDCFE"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                    </ToolBar>

                    <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding PdfSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search PDF filenames"/>
                    </Border>

                    <DataGrid Grid.Row="2"
                              x:Name="PdfFileGrid"
                              ItemsSource="{Binding PdfFileRows}"
                              IsReadOnly="True"
                              SelectionChanged="PdfFileGrid_SelectionChanged"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Scale Selected..." Click="PdfScale_Click"/>
                                <MenuItem Header="Delete Selected" Click="PdfDelete_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PDF File" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Sales Orders" Binding="{Binding SalesOrders}" Width="220"/>
                            <DataGridTextColumn Header="Import Date/Time"
                                                Binding="{Binding ImportDateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                Width="190"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="3"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  Background="#3C3C3C"/>

                    <DockPanel Grid.Row="4">
                        <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C"
                                BorderThickness="0,0,0,1" Padding="10,8">
                            <DockPanel>
                                <Button x:Name="PdfEditorSaveBtn"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource ToolbarButton}"
                                        Content="Save"
                                        Margin="8,0,0,0"
                                        Click="PdfEditorSave_Click"/>
                            <Button x:Name="PdfEditorViewModeBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PdfModeButton}"
                                Content="View"
                                Margin="8,0,0,0"
                                Click="PdfEditorViewMode_Click"/>
                            <Button x:Name="PdfEditorEditModeBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PdfModeButton}"
                                Content="Edit"
                                Margin="8,0,0,0"
                                Click="PdfEditorEditMode_Click"/>
                                <TextBlock x:Name="PdfEditorSelectedFileText"
                                           Text="Select a PDF from the list above"
                                           Foreground="#D4D4D4"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="Selected PDF file"/>
                            </DockPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                          Background="#1E1E1E" Padding="16,12">
                                <StackPanel>

                                    <TextBlock Text="GLOBAL SETTINGS"
                                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#569CD6" Margin="0,0,0,10"/>

                                    <TextBlock Text="Text Size Y (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,0,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtSizeY" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="175" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldSizeY" Minimum="50" Maximum="300"
                                                Value="175" TickFrequency="5"
                                                ValueChanged="SldSizeY_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Text Size X (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtSizeX" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldSizeX" Minimum="25" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldSizeX_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Zoom X (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtZoomX" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldZoomX" Minimum="50" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldZoomX_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Zoom Y (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtZoomY" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldZoomY" Minimum="50" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldZoomY_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Size X (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtPageSizeX" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldPageSizeX" Minimum="25" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldPageSizeX_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Size Y (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtPageSizeY" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldPageSizeY" Minimum="25" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldPageSizeY_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Font" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <TextBox x:Name="TxtFont"
                                             Style="{StaticResource SearchBox}"
                                             Text="" Margin="0,0,0,2"
                                             TextChanged="GlobalSetting_Changed"/>

                                    <CheckBox x:Name="ChkBold"
                                              Content="Bold Text"
                                              Foreground="#D4D4D4"
                                              FontFamily="Consolas" FontSize="12"
                                              Margin="0,10,0,16"
                                              Checked="GlobalSetting_Changed"
                                              Unchecked="GlobalSetting_Changed"/>

                                    <TextBlock Text="RUN OVERRIDES"
                                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#569CD6" Margin="0,0,0,10"/>
                                    <DataGrid x:Name="RunOverridesGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="True"
                                              CanUserDeleteRows="True"
                                              MinHeight="120"
                                              Background="#252526"
                                              Foreground="#D4D4D4"
                                              BorderBrush="#3C3C3C"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#3C3C3C"
                                              RowBackground="#252526"
                                              AlternatingRowBackground="#2D2D2D"
                                              FontFamily="Consolas" FontSize="12"
                                              CellEditEnding="RunOverrides_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Page" Binding="{Binding Page}" Width="44"/>
                                            <DataGridTextColumn Header="Run" Binding="{Binding RunIndex}" Width="44"/>
                                            <DataGridTextColumn Header="Preview Text" Binding="{Binding PreviewText}" Width="*" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Nudge X (pt)" Binding="{Binding NudgeX}" Width="90"/>
                                            <DataGridTextColumn Header="Nudge Y (pt)" Binding="{Binding NudgeY}" Width="90"/>
                                            <DataGridTextColumn Header="Size (%)" Binding="{Binding SizeScale}" Width="72"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                </StackPanel>
                            </ScrollViewer>

                            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                          Background="#3C3C3C"/>

                            <Border Grid.Column="2" Background="#111" ClipToBounds="True">
                                <ScrollViewer x:Name="PdfEditorScroll"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <Grid x:Name="PdfEditorCanvas" Width="390"
                                          HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <Image x:Name="PdfEditorImage"
                                               Stretch="None"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"/>
                                        <Canvas x:Name="PdfEditorOverlay"
                                                IsHitTestVisible="False"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>

                        </Grid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ── Server ────────────────────────────────────────────────── -->
            <TabItem Header="Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <StackPanel Margin="24,20,24,24" MaxWidth="680">

                        <!-- HTTP SERVER ─────────────────────────────────── -->
                        <TextBlock Text="HTTP SERVER"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="Auto" MinHeight="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="#4EC9A0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Running" FontFamily="Consolas" FontSize="12" Foreground="#4EC9A0"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="HTTP / WebSocket Port"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HttpPortDisplay}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="WebSocket URL"
                                           VerticalAlignment="Top" Margin="0,6,0,0"
                                           FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HubUrlDisplay}"
                                           VerticalAlignment="Top" Margin="0,6,0,6"
                                           FontFamily="Consolas" FontSize="12" Foreground="#9CDCFE"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- LOCAL NETWORK ───────────────────────────────── -->
                        <TextBlock Text="LOCAL NETWORK"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Local IP(s)"
                                           VerticalAlignment="Top" Margin="0,6,0,0"
                                           FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalAddressesDisplay}"
                                           VerticalAlignment="Top" Margin="0,6,0,6"
                                           FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"
                                           TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Connected Clients"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientCountText}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Device"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastConnectedDeviceDisplay}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                            </Grid>
                        </Border>

                        <!-- UDP DISCOVERY BROADCAST ─────────────────────── -->
                        <TextBlock Text="UDP DISCOVERY BROADCAST"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7" Fill="{Binding BroadcastDotColor}"
                                                 Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding BroadcastStatusText}"
                                                   Foreground="{Binding BroadcastTextColor}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Beacon Destination"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BeaconDestinationDisplay}"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Beacon Interval"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="3 seconds"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                                </Grid>

                                <Button Content="{Binding BroadcastButtonText}"
                                        Click="Broadcast_Toggle"
                                        Style="{StaticResource ToolbarButton}"
                                        HorizontalAlignment="Left"
                                        MinWidth="210"
                                        Margin="0,0,0,10"/>

                                <TextBlock Text="{Binding LastBeaconText}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#555"/>
                            </StackPanel>
                        </Border>

                        <!-- Firewall note ────────────────────────────────── -->
                        <Border Background="#1C1C1C" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="ⓘ  Firewall Note"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#858585" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Broadcasting uses UDP outbound only — no inbound firewall rule needed for discovery.  If TCP 5050 is blocked by Windows Firewall, run once as Administrator or add an inbound rule for port 5050."
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Dev Tools ─────────────────────────────────────────────── -->
            <TabItem Header="Dev Tools" x:Name="DevToolsTab">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <TextBlock Text="Browser"
                                   Foreground="#D4D4D4"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <ComboBox Width="120"
                                  ItemsSource="{Binding DevBrowserOptions}"
                                  SelectedItem="{Binding DevBrowserKind, UpdateSourceTrigger=PropertyChanged}"
                                  Background="#1E1E1E"
                                  Foreground="#D4D4D4"
                                  BorderBrush="#3C3C3C"
                                  BorderThickness="1"
                                  Margin="0,0,8,0"/>
                        <TextBox Width="260"
                                 Text="{Binding DevBrowserExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Optional custom browser path (used when Browser = Custom)"
                                 Background="#1E1E1E"
                                 Foreground="#D4D4D4"
                                 BorderBrush="#3C3C3C"
                                 BorderThickness="1"
                                 Padding="6,3"
                                 Margin="0,0,8,0"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Browse..." Click="DevCdp_BrowseBrowserExe" Margin="0,0,8,0"/>
                        <TextBlock Text="CDP Endpoint"
                                   Foreground="#D4D4D4"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <Grid Width="220" Margin="0,0,8,0">
                            <TextBox Text="{Binding DevChromeEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E1E1E"
                                     Foreground="#D4D4D4"
                                     BorderBrush="#3C3C3C"
                                     BorderThickness="1"
                                     Padding="6,3"
                                     Visibility="{Binding EndpointEditorVisibility}"/>
                            <Border Background="#1E1E1E"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1"
                                    Padding="6,3"
                                    Visibility="{Binding EndpointMaskedVisibility}">
                                <TextBlock Text="{Binding DevChromeEndpointMasked}"
                                           Foreground="#D4D4D4"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <Button Style="{StaticResource ToolbarButton}" Content="Launch Debug Chrome" Click="DevCdp_LaunchChrome"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Refresh Tabs" Click="DevCdp_RefreshTabs"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Connect" Click="DevCdp_Connect"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Disconnect" Click="DevCdp_Disconnect"/>
                        <Button Style="{StaticResource DeleteButton}" Content="Clear Log" Click="DevCdp_ClearLog"/>
                    </ToolBar>

                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Use local browser data"
                                      IsChecked="{Binding DevUseLocalBrowserData, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#D4D4D4"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <CheckBox Content="Direct local profile (no snapshot)"
                                      IsChecked="{Binding DevUseDirectLocalProfile, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#D4D4D4"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <CheckBox Content="Auto-connect first tab"
                                      IsChecked="{Binding DevAutoConnectFirstTab, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#D4D4D4"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <TextBlock Text="User Data Dir"
                                       Foreground="#858585"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Width="420"
                                     Text="{Binding DevBrowserUserDataDir, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E1E1E"
                                     Foreground="#D4D4D4"
                                     BorderBrush="#3C3C3C"
                                     BorderThickness="1"
                                     Padding="6,3"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Profile"
                                       Foreground="#858585"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Width="160"
                                      IsEditable="True"
                                      ItemsSource="{Binding DevDetectedBrowserProfiles}"
                                      Text="{Binding DevBrowserProfileDirectory, UpdateSourceTrigger=PropertyChanged}"
                                      Background="#1E1E1E"
                                      Foreground="#D4D4D4"
                                      BorderBrush="#3C3C3C"
                                      BorderThickness="1"
                                      Margin="0,0,8,0"/>
                            <Button Style="{StaticResource ToolbarButton}" Content="Detect Profiles" Click="DevCdp_DetectProfiles" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource ToolbarButton}" Content="Use Local Chrome Data" Click="DevCdp_UseLocalChromeData"/>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Chrome Tab"
                                       Foreground="#858585"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox x:Name="DevCdpTabsCombo"
                                      Width="760"
                                      ItemsSource="{Binding DevCdpTabs}"
                                      SelectedItem="{Binding DevSelectedCdpTab}"
                                      Background="#1E1E1E"
                                      Foreground="#D4D4D4"
                                      BorderBrush="#3C3C3C"
                                      BorderThickness="1"/>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBlock Text="{Binding DevCdpStatusDisplay}"
                                   Foreground="#9CDCFE"
                                   FontFamily="Consolas"
                                   FontSize="12"/>
                    </Border>

                    <ListBox x:Name="DevCdpEventsList"
                             ItemsSource="{Binding DevCdpEvents}"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderBrush="#3C3C3C"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
