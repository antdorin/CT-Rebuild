<Window x:Class="CTHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CTHub"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CT Hub"
        Height="780" Width="1100"
        MinHeight="500" MinWidth="700"
        Background="#1E1E1E">

    <Window.Resources>
        <SolidColorBrush x:Key="DropDownTextBrush" Color="#303030"/>

        <!-- Shared DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3C3C3C"/>
            <Setter Property="VerticalGridLinesBrush" Value="#3C3C3C"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <EventSetter Event="ContextMenuOpening" Handler="ColumnHeader_ContextMenuOpening"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Shared GroupItem style — renders group headers like DataGridColumnHeaders -->
        <Style x:Key="SectionGroupContainerStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <StackPanel>
                            <Border Padding="8,4" BorderThickness="0,0,0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1E1E1E"/>
                                        <Setter Property="BorderBrush" Value="#3C3C3C"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Name}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#9CDCFE" FontFamily="Consolas"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                            <ItemsPresenter/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#5C1A1A"/>
            <Setter Property="BorderBrush" Value="#8B2020"/>
        </Style>
        <Style x:Key="PdfModeButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinWidth" Value="68"/>
        </Style>
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource DropDownTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Resources>
                <Style TargetType="TextBox">
                    <Setter Property="Foreground" Value="{StaticResource DropDownTextBrush}"/>
                </Style>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource DropDownTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ── Status Bar ──────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#007ACC" Foreground="White"
                   FontFamily="Consolas" FontSize="12">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusTextDisplay}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ClientCountText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding LastBroadcast}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <CheckBox Content="Privacy Mode"
                          IsChecked="{Binding IsPrivacyModeOn, UpdateSourceTrigger=PropertyChanged}"
                          Foreground="White"
                          VerticalAlignment="Center"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Backup / Restore ────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Backup"  Click="BackupData_Click"
                            Background="#0E639C" Foreground="White"
                            FontFamily="Consolas" FontSize="12"
                            Padding="14,4" Margin="6,0,0,0"
                            BorderBrush="#1177BB" Cursor="Hand"/>
                    <Button Content="Restore" Click="RestoreData_Click"
                            Background="#0E639C" Foreground="White"
                            FontFamily="Consolas" FontSize="12"
                            Padding="14,4" Margin="6,0,0,0"
                            BorderBrush="#1177BB" Cursor="Hand"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#808080" FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap"
                           Text="App data (columns, settings, picking tickets) is stored in %APPDATA%\CT-Hub. Use Backup to copy it into this project folder, and Restore to load it on another computer."/>
            </DockPanel>
        </Border>

        <!-- ── Tab Control ─────────────────────────────────────────────────── -->
        <TabControl Background="#1E1E1E" BorderBrush="#3C3C3C"
                    Foreground="#D4D4D4">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#9CDCFE"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ── Chase Tactical ─────────────────────────────────────────── -->
            <TabItem Header="Chase Tactical">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526" Band="1">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ChaseTactical_Add"/>
                        <Button Style="{StaticResource ToolbarButton}"
                            Content="⇪  Import Bulk"
                            Click="ChaseTactical_ImportBulk"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ChaseTactical_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ChaseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search bin, label, qty, stock threshold, notes, id"/>
                    </Border>
                    <Grid>
                        <DataGrid x:Name="ChaseTacticalGrid"
                                  ItemsSource="{Binding ChaseTacticalItems}"
                                  CanUserSortColumns="False"
                                  CellEditEnding="ChaseTactical_CellEditEnding">
                            <DataGrid.GroupStyle>
                                <GroupStyle ContainerStyle="{StaticResource SectionGroupContainerStyle}"/>
                            </DataGrid.GroupStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add Row" Click="ChaseTactical_Add"/>
                                    <MenuItem Header="Import Bulk" Click="ChaseTactical_ImportBulk"/>
                                    <MenuItem Header="Delete Selected" Click="ChaseTactical_Delete"/>
                                    <Separator/>
                                    <MenuItem Header="⊞  Set Section…" Click="ChaseTactical_SetSection"/>
                                    <MenuItem Header="✕  Clear Section" Click="ChaseTactical_ClearSection"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>

                        </DataGrid>
                        <Button x:Name="ChaseIdColToggleBtn"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="17" Height="26"
                                Tag="ChaseTacticalGrid"
                                Click="IdColToggle_Click"
                                Cursor="Hand"
                                ToolTip="Show / hide ID column"
                                Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                                Foreground="#606060" FontSize="10" Padding="0"
                                Margin="0,0,17,0"
                                Content="&#x25C1;"/>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ── Tough Hooks ───────────────────────────────────────────── -->
            <TabItem Header="Tough Hooks">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ToughHooks_Add"/>
                        <Button Style="{StaticResource ToolbarButton}"
                            Content="⇪  Import Bulk"
                            Click="ToughHooks_ImportBulk"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ToughHooks_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ToughHooksSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search bin, sku, description, qty, stock threshold, id"/>
                    </Border>
                    <Grid>
                        <DataGrid x:Name="ToughHooksGrid"
                                  ItemsSource="{Binding ToughHookItems}"
                                  CanUserSortColumns="False"
                                  CellEditEnding="ToughHooks_CellEditEnding">
                            <DataGrid.GroupStyle>
                                <GroupStyle ContainerStyle="{StaticResource SectionGroupContainerStyle}"/>
                            </DataGrid.GroupStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add Row" Click="ToughHooks_Add"/>
                                    <MenuItem Header="Import Bulk" Click="ToughHooks_ImportBulk"/>
                                    <MenuItem Header="Delete Selected" Click="ToughHooks_Delete"/>
                                    <Separator/>
                                    <MenuItem Header="⊞  Set Section…" Click="ToughHooks_SetSection"/>
                                    <MenuItem Header="✕  Clear Section" Click="ToughHooks_ClearSection"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>

                        </DataGrid>
                        <Button x:Name="ToughHooksIdColToggleBtn"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="17" Height="26"
                                Tag="ToughHooksGrid"
                                Click="IdColToggle_Click"
                                Cursor="Hand"
                                ToolTip="Show / hide ID column"
                                Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                                Foreground="#606060" FontSize="10" Padding="0"
                                Margin="0,0,17,0"
                                Content="&#x25C1;"/>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ── Shipping Supplys ─────────────────────────────────────── -->
            <TabItem Header="Shipping Supplys">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ShippingSupplys_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ShippingSupplys_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ShippingSupplysSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search dimensions, bundle, single, stock threshold, id"/>
                    </Border>
                    <Grid>
                        <DataGrid x:Name="ShippingSupplysGrid"
                                  ItemsSource="{Binding ShippingSupplysItems}"
                                  CanUserSortColumns="False"
                                  CellEditEnding="ShippingSupplys_CellEditEnding">
                            <DataGrid.GroupStyle>
                                <GroupStyle ContainerStyle="{StaticResource SectionGroupContainerStyle}"/>
                            </DataGrid.GroupStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add Row" Click="ShippingSupplys_Add"/>
                                    <MenuItem Header="Delete Selected" Click="ShippingSupplys_Delete"/>
                                    <Separator/>
                                    <MenuItem Header="⊞  Set Section…" Click="ShippingSupplys_SetSection"/>
                                    <MenuItem Header="✕  Clear Section" Click="ShippingSupplys_ClearSection"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                        <Button x:Name="ShippingSupplysIdColToggleBtn"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="17" Height="26"
                                Tag="ShippingSupplysGrid"
                                Click="IdColToggle_Click"
                                Cursor="Hand"
                                ToolTip="Show / hide ID column"
                                Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                                Foreground="#606060" FontSize="10" Padding="0"
                                Margin="0,0,17,0"
                                Content="&#x25C1;"/>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ── Code Mappings ─────────────────────────────────────────── -->
            <TabItem Header="Code Mappings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="190" MinHeight="140"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ToolBar Grid.Row="0" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="🖨  Print"
                                Click="QrGenerator_Print"/>
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="Copy ZPL"
                                Click="QrGenerator_CopyZpl"/>
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="Use Selected QR"
                                Click="QrGenerator_UseSelected"/>
                    </ToolBar>

                    <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding QrMappingsSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search QR value, classification, description, id"/>
                    </Border>

                    <DataGrid Grid.Row="2"
                              x:Name="QrMappingsGrid"
                              ItemsSource="{Binding QrMappingItems}"
                              CanUserSortColumns="False"
                              SelectionChanged="QrMappings_SelectionChanged"
                              CellEditEnding="QrMappings_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="QrMappings_Add"/>
                                <MenuItem Header="Delete Selected" Click="QrMappings_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>

                    <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

                    <DockPanel Grid.Row="4">
                        <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C"
                                BorderThickness="0,0,0,1" Padding="6,5">
                            <UniformGrid Rows="1" Columns="4">
                                <Button Style="{StaticResource ToolbarButton}"
                                        Content="＋  New"
                                        Margin="2,0"
                                        Click="QrMappings_Add"/>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Content="Save"
                                        Margin="2,0"
                                        Click="QrMappings_Save"/>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Content="Reset to Default"
                                        Margin="2,0"
                                        Click="QrGen_ResetToDefault"/>
                                <Button Style="{StaticResource DeleteButton}"
                                        Content="✕  Delete"
                                        Margin="2,0"
                                        Click="QrMappings_Delete"/>
                            </UniformGrid>
                        </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="370" MinWidth="320"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1B1B1B" BorderBrush="#2F2F2F" BorderThickness="0,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <TextBlock Text="LABEL CONFIGURATION"
                                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#569CD6" Margin="0,0,0,8"/>

                                    <TextBlock Text="Payload" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,4,0,3"/>
                                    <TextBox x:Name="QrGenPayload"
                                             Style="{StaticResource SearchBox}"
                                             Text="SCAN_ME"
                                             TextChanged="QrGenerator_TextChanged"/>
                                    <DockPanel Margin="0,4,0,0">
                                        <ComboBox x:Name="QrGenUpcALeadDigit"
                                                  DockPanel.Dock="Left"
                                                  Width="46" Padding="6,4"
                                                  FontFamily="Consolas" FontSize="11"
                                                  ToolTip="Number system digit to prepend (0 = standard retail)"/>
                                        <Button Content="⬆ Pad to UPC-A"
                                                Click="QrGenPadUpcA_Click"
                                                Padding="10,4" Margin="4,0,0,0"
                                                FontFamily="Consolas" FontSize="11"
                                                ToolTip="Prepend selected digit to 11 digits, recalculate check → valid 12-digit UPC-A"/>
                                    </DockPanel>

                                    <DockPanel Margin="0,8,0,2">
                                        <TextBlock Text="Code Type" Foreground="#9CDCFE"
                                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <RadioButton x:Name="QrGenTypeQr" Content="QR" IsChecked="True"
                                                         Foreground="#D4D4D4" Margin="0,0,12,0"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                            <RadioButton x:Name="QrGenTypeBarcode" Content="Barcode 128"
                                                         Foreground="#D4D4D4" Margin="0,0,12,0"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                            <RadioButton x:Name="QrGenTypeUpcA" Content="UPC-A"
                                                         Foreground="#D4D4D4"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <CheckBox x:Name="QrGenAutoFromSelection"
                                              Content="Auto-fill payload from selected mapping"
                                              IsChecked="True"
                                              Foreground="#D4D4D4"
                                              FontFamily="Consolas" FontSize="11"
                                              Margin="0,2,0,10"
                                              Checked="QrGenerator_ToggleChanged"
                                              Unchecked="QrGenerator_ToggleChanged"/>

                                    <DockPanel Margin="0,8,0,2">
                                        <TextBlock Text="Units" Foreground="#9CDCFE"
                                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <RadioButton Content="in" IsChecked="True"
                                                         Foreground="#D4D4D4" Margin="0,0,12,0"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                            <RadioButton x:Name="QrGenUnitMm" Content="mm"
                                                         Foreground="#D4D4D4"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Printer DPI" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,4,0,3"/>
                                    <ComboBox x:Name="QrGenDpi"
                                              Background="#2A2A2A" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#4A4A4A"
                                              SelectionChanged="QrGenerator_SelectionChanged">
                                        <ComboBoxItem Content="203"/>
                                        <ComboBoxItem Content="300"/>
                                        <ComboBoxItem Content="600"/>
                                    </ComboBox>

                                    <TextBlock Text="Label Preset" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <ComboBox x:Name="QrGenPreset"
                                              Background="#2A2A2A" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#4A4A4A"
                                              SelectionChanged="QrGenerator_PresetChanged">
                                        <ComboBoxItem Content="4x6 Shipping (203 DPI)"/>
                                        <ComboBoxItem Content="2x1 Asset Tag (300 DPI)"/>
                                        <ComboBoxItem Content="4x2 Product Label (203 DPI)"/>
                                        <ComboBoxItem Content="Custom"/>
                                    </ComboBox>

                                    <TextBlock Text="Label Width (in)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel>
                                        <TextBox x:Name="QrGenLabelWidthIn"
                                                 DockPanel.Dock="Right"
                                                 Width="64" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}" Text="4.0"
                                                 TextChanged="QrGenerator_TextChanged"/>
                                        <Slider x:Name="QrGenLabelWidthInSlider"
                                                Minimum="0.5" Maximum="12"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="False"
                                                Value="4.0"
                                                ValueChanged="QrGenerator_NumberSliderChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Label Height (in)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel>
                                        <TextBox x:Name="QrGenLabelHeightIn"
                                                 DockPanel.Dock="Right"
                                                 Width="64" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}" Text="2.0"
                                                 TextChanged="QrGenerator_TextChanged"/>
                                        <Slider x:Name="QrGenLabelHeightInSlider"
                                                Minimum="0.5" Maximum="12"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="False"
                                                Value="2.0"
                                                ValueChanged="QrGenerator_NumberSliderChanged"/>
                                    </DockPanel>

                                    <TextBlock x:Name="QrGenMarginXLabel" Text="Margin X (in)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel>
                                        <TextBox x:Name="QrGenMarginX"
                                                 DockPanel.Dock="Right"
                                                 Width="64" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}" Text="24"
                                                 TextChanged="QrGenerator_TextChanged"/>
                                        <Slider x:Name="QrGenMarginXSlider"
                                                Minimum="0" Maximum="400"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                Value="24"
                                                ValueChanged="QrGenerator_NumberSliderChanged"/>
                                    </DockPanel>

                                    <TextBlock x:Name="QrGenMarginYLabel" Text="Margin Y (in)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel>
                                        <TextBox x:Name="QrGenMarginY"
                                                 DockPanel.Dock="Right"
                                                 Width="64" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}" Text="24"
                                                 TextChanged="QrGenerator_TextChanged"/>
                                        <Slider x:Name="QrGenMarginYSlider"
                                                Minimum="0" Maximum="400"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                Value="24"
                                                ValueChanged="QrGenerator_NumberSliderChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Module Width (dots)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel>
                                        <TextBox x:Name="QrGenModuleDots"
                                                 DockPanel.Dock="Right"
                                                 Width="64" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}" Text="4"
                                                 TextChanged="QrGenerator_TextChanged"/>
                                        <Slider x:Name="QrGenModuleDotsSlider"
                                                Minimum="1" Maximum="40"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                Value="4"
                                                ValueChanged="QrGenerator_NumberSliderChanged"/>
                                    </DockPanel>

                                    <TextBlock x:Name="QrGenQuietZoneLabel" Text="Quiet Zone (in)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel>
                                        <TextBox x:Name="QrGenQuietZone"
                                                 DockPanel.Dock="Right"
                                                 Width="64" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}" Text="4"
                                                 TextChanged="QrGenerator_TextChanged"/>
                                        <Slider x:Name="QrGenQuietZoneSlider"
                                                Minimum="0" Maximum="20"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                Value="4"
                                                ValueChanged="QrGenerator_NumberSliderChanged"/>
                                    </DockPanel>

                                    <TextBlock x:Name="QrGenBarcodeHeightLabel" Text="Barcode Height (in)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel>
                                        <TextBox x:Name="QrGenBarcodeHeight"
                                                 DockPanel.Dock="Right"
                                                 Width="64" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}" Text="120"
                                                 TextChanged="QrGenerator_TextChanged"/>
                                        <Slider x:Name="QrGenBarcodeHeightSlider"
                                                Minimum="20" Maximum="1200"
                                                TickFrequency="5"
                                                IsSnapToTickEnabled="True"
                                                Value="120"
                                                ValueChanged="QrGenerator_NumberSliderChanged"/>
                                    </DockPanel>

                                    <CheckBox x:Name="QrGenIncludeText"
                                              Content="Show human-readable text for barcode"
                                              IsChecked="True"
                                              Foreground="#D4D4D4"
                                              FontFamily="Consolas" FontSize="11"
                                              Margin="0,10,0,8"
                                              Checked="QrGenerator_ToggleChanged"
                                              Unchecked="QrGenerator_ToggleChanged"/>

                                    <DockPanel Margin="0,4,0,2">
                                        <TextBlock Text="Alignment" Foreground="#9CDCFE"
                                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <RadioButton x:Name="QrGenAlignLeft" Content="Left"
                                                         Foreground="#D4D4D4" Margin="0,0,10,0"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                            <RadioButton Content="Center" IsChecked="True"
                                                         Foreground="#D4D4D4" Margin="0,0,10,0"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                            <RadioButton x:Name="QrGenAlignRight" Content="Right"
                                                         Foreground="#D4D4D4"
                                                         Checked="QrGenerator_ToggleChanged"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Top Line 1" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <TextBox x:Name="QrGenTopLine1"
                                             Style="{StaticResource SearchBox}"
                                             TextChanged="QrGenerator_TextChanged"/>

                                    <TextBlock Text="Top Line 2" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,6,0,3"/>
                                    <TextBox x:Name="QrGenTopLine2"
                                             Style="{StaticResource SearchBox}"
                                             TextChanged="QrGenerator_TextChanged"/>

                                    <TextBlock Text="Bottom Line" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,6,0,3"/>
                                    <TextBox x:Name="QrGenBottomLine"
                                             Style="{StaticResource SearchBox}"
                                             Margin="0,0,0,8"
                                             TextChanged="QrGenerator_TextChanged"/>

                                    <TextBlock Text="ZPL Preview" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <TextBox x:Name="QrGenZplOutput"
                                             FontFamily="Consolas" FontSize="11"
                                             Background="#111111" Foreground="#B5CEA8"
                                             BorderBrush="#3C3C3C" BorderThickness="1"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             Height="140" IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

                        <Border Grid.Column="2" Background="#101010" ClipToBounds="True">
                            <Grid Margin="18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="QrGenInfo"
                                           Grid.Row="0"
                                           Foreground="#9CDCFE"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,0,0,10"/>

                                <Border Grid.Row="1"
                                        Background="#0D0D0D"
                                        BorderBrush="#2C2C2C"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Canvas x:Name="QrGenRulerTop"
                                                Grid.Row="0" Grid.Column="1"
                                                Background="#1A1A1A" ClipToBounds="True"/>
                                        <Canvas x:Name="QrGenRulerLeft"
                                                Grid.Row="1" Grid.Column="0"
                                                Background="#1A1A1A" ClipToBounds="True"/>
                                        <Viewbox x:Name="QrGenPreviewViewbox"
                                                 Grid.Row="1" Grid.Column="1"
                                                 Stretch="Uniform" StretchDirection="DownOnly">
                                            <Border Background="White" Padding="0" BorderBrush="#333" BorderThickness="1">
                                                <Image x:Name="QrGenPreview"
                                                       Stretch="None"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                            </Border>
                                        </Viewbox>
                                    </Grid>
                                </Border>

                                <TextBlock x:Name="QrGenHint"
                                           Grid.Row="2"
                                           Margin="0,10,0,0"
                                           Foreground="#808080"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Text="Binary black/white preview mapped to printer dots. Use this for Zebra-safe sizing."/>
                            </Grid>
                        </Border>
                    </Grid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ── PDF Editor ─────────────────────────────────────────────── -->
            <TabItem Header="PDF Editor">
                <Grid x:Name="PdfEditorTabGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="PdfEditorFileListRow" Height="240" MinHeight="160"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition x:Name="PdfEditorWorkspaceRow" Height="*"/>
                    </Grid.RowDefinitions>

                    <ToolBar Grid.Row="0" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="📂  Browse…"
                                Click="PdfFolder_Browse"/>
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="⚖  Scale Selected…"
                                Click="PdfScale_Click"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="🗑  Delete Selected"
                                Click="PdfDelete_Click"/>
                        <Separator/>
                        <TextBlock x:Name="PdfFolderPathText"
                                   Text="No folder selected"
                                   Foreground="#9CDCFE"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                    </ToolBar>

                    <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding PdfSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search PDF filenames"/>
                    </Border>

                    <DataGrid Grid.Row="2"
                              x:Name="PdfFileGrid"
                              ItemsSource="{Binding PdfFileRows}"
                              IsReadOnly="True"
                              SelectionChanged="PdfFileGrid_SelectionChanged"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Scale Selected..." Click="PdfScale_Click"/>
                                <MenuItem Header="Delete Selected" Click="PdfDelete_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PDF File" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Sales Orders" Binding="{Binding SalesOrders}" Width="220"/>
                            <DataGridTextColumn Header="Import Date/Time"
                                                Binding="{Binding ImportDateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                Width="190"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter x:Name="PdfEditorRowSplitter"
                                  Grid.Row="3"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  DragStarted="PdfEditorRowSplitter_DragStarted"
                                  DragDelta="PdfEditorRowSplitter_DragDelta"
                                  DragCompleted="PdfEditorRowSplitter_DragCompleted"
                                  Background="#3C3C3C"/>

                    <DockPanel Grid.Row="4">
                        <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C"
                                BorderThickness="0,0,0,1" Padding="10,8">
                            <DockPanel>
                            <Button x:Name="PdfEditorSaveAllBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource ToolbarButton}"
                                Content="Save All"
                                Margin="8,0,0,0"
                                Click="PdfEditorSaveAll_Click"/>
                                <Button x:Name="PdfEditorSaveBtn"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource ToolbarButton}"
                                        Content="Save"
                                        Margin="8,0,0,0"
                                        Click="PdfEditorSave_Click"/>
                            <Button x:Name="PdfEditorWebModeBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PdfModeButton}"
                                Content="🌐 Web"
                                Margin="8,0,0,0"
                                Click="PdfEditorWebMode_Click"/>
                            <Button x:Name="PdfEditorViewModeBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PdfModeButton}"
                                Content="View"
                                Margin="8,0,0,0"
                                Click="PdfEditorViewMode_Click"/>
                            <Button x:Name="PdfEditorEditModeBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PdfModeButton}"
                                Content="Edit"
                                Margin="8,0,0,0"
                                Click="PdfEditorEditMode_Click"/>
                            <Button x:Name="PdfEditorRunEditBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PdfModeButton}"
                                Content="✏ Edit Runs: Off"
                                Margin="8,0,0,0"
                                Click="PdfEditorRunEdit_Click"/>
                                <TextBlock x:Name="PdfEditorSelectedFileText"
                                           Text="Select a PDF from the list above"
                                           Foreground="#D4D4D4"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="Selected PDF file"/>
                            </DockPanel>
                        </Border>

                        <Grid x:Name="PdfEditorSurfaceGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="PdfEditorSettingsColumn" Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition x:Name="PdfEditorPreviewColumn" Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                          Background="#1E1E1E" Padding="16,12">
                                <StackPanel>

                                    <TextBlock Text="GLOBAL SETTINGS"
                                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#569CD6" Margin="0,0,0,10"/>

                                    <TextBlock Text="Font" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="TxtFont"
                                              IsEditable="True"
                                              Text="Verdana"
                                              Background="#3C3C3C" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#555555"
                                              FontFamily="Consolas" FontSize="12"
                                              Margin="0,0,0,10"
                                              SelectionChanged="FontCombo_SelectionChanged">
                                        <ComboBoxItem Content="Verdana"/>
                                        <ComboBoxItem Content="Segoe UI"/>
                                        <ComboBoxItem Content="Arial"/>
                                        <ComboBoxItem Content="Calibri"/>
                                        <ComboBoxItem Content="Consolas"/>
                                        <ComboBoxItem Content="Courier New"/>
                                        <ComboBoxItem Content="Georgia"/>
                                        <ComboBoxItem Content="Helvetica"/>
                                        <ComboBoxItem Content="Impact"/>
                                        <ComboBoxItem Content="Lucida Console"/>
                                        <ComboBoxItem Content="Tahoma"/>
                                        <ComboBoxItem Content="Times New Roman"/>
                                        <ComboBoxItem Content="Trebuchet MS"/>
                                        <ComboBoxItem Content="Century Gothic"/>
                                        <ComboBoxItem Content="Franklin Gothic Medium"/>
                                        <ComboBoxItem Content="Palatino Linotype"/>
                                        <ComboBoxItem Content="Garamond"/>
                                        <ComboBoxItem Content="Book Antiqua"/>
                                        <ComboBoxItem Content="Candara"/>
                                        <ComboBoxItem Content="Segoe UI Semibold"/>
                                    </ComboBox>

                                    <TextBlock Text="Text Size Y (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,0,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtSizeY" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldSizeY" Minimum="50" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldSizeY_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Text Size X (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtSizeX" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldSizeX" Minimum="25" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldSizeX_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Zoom X (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtZoomX" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldZoomX" Minimum="50" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldZoomX_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Zoom Y (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtZoomY" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldZoomY" Minimum="50" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldZoomY_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Size X (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtPageSizeX" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldPageSizeX" Minimum="25" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldPageSizeX_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Page Size Y (%)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtPageSizeY" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldPageSizeY" Minimum="25" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldPageSizeY_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Text Spacing X (px)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtSpacingX" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="0" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldSpacingX" Minimum="-2" Maximum="12"
                                                Value="0" TickFrequency="1"
                                                ValueChanged="SldSpacingX_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Text="Text Spacing Y (line %)" Foreground="#9CDCFE"
                                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,3"/>
                                    <DockPanel Margin="0,0,0,2">
                                        <TextBox x:Name="TxtSpacingY" DockPanel.Dock="Right"
                                                 Width="60" Margin="8,0,0,0"
                                                 Style="{StaticResource SearchBox}"
                                                 Text="100" TextChanged="GlobalSetting_Changed"/>
                                        <Slider x:Name="SldSpacingY" Minimum="50" Maximum="300"
                                                Value="100" TickFrequency="5"
                                                ValueChanged="SldSpacingY_ValueChanged"/>
                                    </DockPanel>

                                    <CheckBox x:Name="ChkBold"
                                              Content="Bold Text"
                                              Foreground="#D4D4D4"
                                              FontFamily="Consolas" FontSize="12"
                                              Margin="0,10,0,16"
                                              Checked="GlobalSetting_Changed"
                                              Unchecked="GlobalSetting_Changed"/>

                                        <Button Content="Reset To Default"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,0,16"
                                            Padding="14,6"
                                            Style="{StaticResource ToolbarButton}"
                                            Click="PdfEditorResetDefaults_Click"/>

                                    <TextBlock Text="RUN OVERRIDES"
                                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#569CD6" Margin="0,0,0,10"/>
                                    <DataGrid x:Name="RunOverridesGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="True"
                                              CanUserDeleteRows="True"
                                              MinHeight="120"
                                              Background="#252526"
                                              Foreground="#D4D4D4"
                                              BorderBrush="#3C3C3C"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#3C3C3C"
                                              RowBackground="#252526"
                                              AlternatingRowBackground="#2D2D2D"
                                              FontFamily="Consolas" FontSize="12"
                                              CellEditEnding="RunOverrides_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Page" Binding="{Binding Page}" Width="44"/>
                                            <DataGridTextColumn Header="Run" Binding="{Binding RunIndex}" Width="44"/>
                                            <DataGridTextColumn Header="Preview Text" Binding="{Binding PreviewText}" Width="*" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Nudge X (pt)" Binding="{Binding NudgeX}" Width="90"/>
                                            <DataGridTextColumn Header="Nudge Y (pt)" Binding="{Binding NudgeY}" Width="90"/>
                                            <DataGridTextColumn Header="Size (%)" Binding="{Binding SizeScale}" Width="72"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                </StackPanel>
                            </ScrollViewer>

                            <GridSplitter x:Name="PdfEditorColumnSplitter"
                                          Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                          DragStarted="PdfEditorColumnSplitter_DragStarted"
                                          DragDelta="PdfEditorColumnSplitter_DragDelta"
                                          DragCompleted="PdfEditorColumnSplitter_DragCompleted"
                                          Background="#3C3C3C"/>

                            <Grid Grid.Column="2" Background="#111" ClipToBounds="True">
                                <ScrollViewer x:Name="PdfEditorScroll"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <Grid x:Name="PdfEditorCanvas" Width="390"
                                          HorizontalAlignment="Center" VerticalAlignment="Top">
                                        <Image x:Name="PdfEditorImage"
                                               Stretch="None"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"/>
                                        <Canvas x:Name="PdfEditorOverlay"
                                                IsHitTestVisible="False"/>
                                    </Grid>
                                </ScrollViewer>
                                <wv2:WebView2 x:Name="PdfEditorWebView" Visibility="Collapsed"/>
                            </Grid>

                        </Grid>
                    </DockPanel>

                        <Canvas Grid.RowSpan="5"
                            IsHitTestVisible="False"
                            Panel.ZIndex="1000">
                        <Border x:Name="PdfEditorResizeIndicatorBorder"
                                Visibility="Collapsed"
                                Padding="10,4"
                                Background="#CC0D0D0D"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock x:Name="PdfEditorResizeIndicatorText"
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                        </Border>
                    </Canvas>
                </Grid>
            </TabItem>

            <!-- ── Maintenance ────────────────────────────────────────────── -->
            <TabItem Header="Maintenance">
                <Grid Background="#1E1E1E"/>
            </TabItem>

            <!-- ── Server ────────────────────────────────────────────────── -->
            <TabItem Header="Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <StackPanel Margin="24,20,24,24" MaxWidth="680">

                        <!-- HTTP SERVER ─────────────────────────────────── -->
                        <TextBlock Text="HTTP SERVER"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="Auto" MinHeight="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="#4EC9A0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Running" FontFamily="Consolas" FontSize="12" Foreground="#4EC9A0"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="HTTP / WebSocket Port"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HttpPortDisplay}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="WebSocket URL"
                                           VerticalAlignment="Top" Margin="0,6,0,0"
                                           FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HubUrlDisplay}"
                                           VerticalAlignment="Top" Margin="0,6,0,6"
                                           FontFamily="Consolas" FontSize="12" Foreground="#9CDCFE"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- LOCAL NETWORK ───────────────────────────────── -->
                        <TextBlock Text="LOCAL NETWORK"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Local IP(s)"
                                           VerticalAlignment="Top" Margin="0,6,0,0"
                                           FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalAddressesDisplay}"
                                           VerticalAlignment="Top" Margin="0,6,0,6"
                                           FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"
                                           TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Connected Clients"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientCountText}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Device"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastConnectedDeviceDisplay}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                            </Grid>
                        </Border>

                        <!-- UDP DISCOVERY BROADCAST ─────────────────────── -->
                        <TextBlock Text="UDP DISCOVERY BROADCAST"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7" Fill="{Binding BroadcastDotColor}"
                                                 Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding BroadcastStatusText}"
                                                   Foreground="{Binding BroadcastTextColor}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Beacon Destination"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BeaconDestinationDisplay}"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Beacon Interval"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="3 seconds"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                                </Grid>

                                <Button Content="{Binding BroadcastButtonText}"
                                        Click="Broadcast_Toggle"
                                        Style="{StaticResource ToolbarButton}"
                                        HorizontalAlignment="Left"
                                        MinWidth="210"
                                        Margin="0,0,0,10"/>

                                <TextBlock Text="{Binding LastBeaconText}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#555"/>
                            </StackPanel>
                        </Border>

                        <!-- Firewall note ────────────────────────────────── -->
                        <Border Background="#1C1C1C" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="ⓘ  Firewall Note"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#858585" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Broadcasting uses UDP outbound only — no inbound firewall rule needed for discovery.  If TCP 5050 is blocked by Windows Firewall, run once as Administrator or add an inbound rule for port 5050."
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Settings ──────────────────────────────────────────────── -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <StackPanel Margin="24,20,24,24" MaxWidth="680">

                        <TextBlock Text="SETTINGS"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>

                        <!-- ── Mobile Card Display ──────────────────────────── -->
                        <TextBlock Text="MOBILE CARD DISPLAY"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,16,0,6"/>
                        <TextBlock Text="Controls what fields appear on each entry card in the Android scan picker."
                                   Foreground="#858585" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <!-- Chase Tactical -->
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="Chase Tactical" Foreground="#D4D4D4"
                                           FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Title (Row 1)"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          x:Name="CT_Row1Combo"
                                          ItemsSource="{Binding MobileCardFieldOptions_CT}"
                                          SelectedValue="{Binding MobileCard_CT_Row1, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                          BorderBrush="#3C3C3C" Margin="0,2,0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Subtitle (Row 2)"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,2">
                                    <ComboBox x:Name="CT_Row2aCombo" Width="180"
                                              ItemsSource="{Binding MobileCardFieldOptions_CT}"
                                              SelectedValue="{Binding MobileCard_CT_Row2a, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#3C3C3C" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="CT_Row2bCombo" Width="180"
                                              ItemsSource="{Binding MobileCardFieldOptions_CT}"
                                              SelectedValue="{Binding MobileCard_CT_Row2b, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#3C3C3C"/>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Badge"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                                          x:Name="CT_BadgeCombo"
                                          ItemsSource="{Binding MobileCardFieldOptions_CT}"
                                          SelectedValue="{Binding MobileCard_CT_Badge, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                          BorderBrush="#3C3C3C"/>
                            </Grid>
                        </Border>

                        <!-- Tough Hooks -->
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="Tough Hooks" Foreground="#D4D4D4"
                                           FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Title (Row 1)"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          x:Name="TH_Row1Combo"
                                          ItemsSource="{Binding MobileCardFieldOptions_TH}"
                                          SelectedValue="{Binding MobileCard_TH_Row1, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                          BorderBrush="#3C3C3C" Margin="0,2,0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Subtitle (Row 2)"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,2">
                                    <ComboBox x:Name="TH_Row2aCombo" Width="180"
                                              ItemsSource="{Binding MobileCardFieldOptions_TH}"
                                              SelectedValue="{Binding MobileCard_TH_Row2a, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#3C3C3C" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="TH_Row2bCombo" Width="180"
                                              ItemsSource="{Binding MobileCardFieldOptions_TH}"
                                              SelectedValue="{Binding MobileCard_TH_Row2b, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#3C3C3C"/>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Badge"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                                          x:Name="TH_BadgeCombo"
                                          ItemsSource="{Binding MobileCardFieldOptions_TH}"
                                          SelectedValue="{Binding MobileCard_TH_Badge, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                          BorderBrush="#3C3C3C"/>
                            </Grid>
                        </Border>

                        <!-- Shipping Supplys -->
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="Shipping Supplys" Foreground="#D4D4D4"
                                           FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Title (Row 1)"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          x:Name="SS_Row1Combo"
                                          ItemsSource="{Binding MobileCardFieldOptions_SS}"
                                          SelectedValue="{Binding MobileCard_SS_Row1, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                          BorderBrush="#3C3C3C" Margin="0,2,0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Subtitle (Row 2)"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,2">
                                    <ComboBox x:Name="SS_Row2aCombo" Width="180"
                                              ItemsSource="{Binding MobileCardFieldOptions_SS}"
                                              SelectedValue="{Binding MobileCard_SS_Row2a, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#3C3C3C" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="SS_Row2bCombo" Width="180"
                                              ItemsSource="{Binding MobileCardFieldOptions_SS}"
                                              SelectedValue="{Binding MobileCard_SS_Row2b, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                              BorderBrush="#3C3C3C"/>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Badge"
                                           Foreground="#858585" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                                          x:Name="SS_BadgeCombo"
                                          ItemsSource="{Binding MobileCardFieldOptions_SS}"
                                          SelectedValue="{Binding MobileCard_SS_Badge, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#1E1E1E" Foreground="{StaticResource DropDownTextBrush}"
                                          BorderBrush="#3C3C3C"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Dev Tools ─────────────────────────────────────────────── -->
            <TabItem Header="Dev Tools" x:Name="DevToolsTab">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <TextBlock Text="Browser"
                                   Foreground="#D4D4D4"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <ComboBox Width="120"
                                  ItemsSource="{Binding DevBrowserOptions}"
                                  SelectedItem="{Binding DevBrowserKind, UpdateSourceTrigger=PropertyChanged}"
                                  Background="#1E1E1E"
                                  Foreground="{StaticResource DropDownTextBrush}"
                                  BorderBrush="#3C3C3C"
                                  BorderThickness="1"
                                  Margin="0,0,8,0"/>
                        <TextBox Width="260"
                                 Text="{Binding DevBrowserExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Optional custom browser path (used when Browser = Custom)"
                                 Background="#1E1E1E"
                                 Foreground="#D4D4D4"
                                 BorderBrush="#3C3C3C"
                                 BorderThickness="1"
                                 Padding="6,3"
                                 Margin="0,0,8,0"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Browse..." Click="DevCdp_BrowseBrowserExe" Margin="0,0,8,0"/>
                        <TextBlock Text="CDP Endpoint"
                                   Foreground="#D4D4D4"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <Grid Width="220" Margin="0,0,8,0">
                            <TextBox Text="{Binding DevChromeEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E1E1E"
                                     Foreground="#D4D4D4"
                                     BorderBrush="#3C3C3C"
                                     BorderThickness="1"
                                     Padding="6,3"
                                     Visibility="{Binding EndpointEditorVisibility}"/>
                            <Border Background="#1E1E1E"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1"
                                    Padding="6,3"
                                    Visibility="{Binding EndpointMaskedVisibility}">
                                <TextBlock Text="{Binding DevChromeEndpointMasked}"
                                           Foreground="#D4D4D4"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <Button Style="{StaticResource ToolbarButton}" Content="Launch Debug Chrome" Click="DevCdp_LaunchChrome"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Refresh Tabs" Click="DevCdp_RefreshTabs"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Connect" Click="DevCdp_Connect"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Disconnect" Click="DevCdp_Disconnect"/>
                        <Button Style="{StaticResource DeleteButton}" Content="Clear Log" Click="DevCdp_ClearLog"/>
                    </ToolBar>

                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Use local browser data"
                                      IsChecked="{Binding DevUseLocalBrowserData, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#D4D4D4"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <CheckBox Content="Direct local profile (no snapshot)"
                                      IsChecked="{Binding DevUseDirectLocalProfile, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#D4D4D4"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <CheckBox Content="Auto-connect first tab"
                                      IsChecked="{Binding DevAutoConnectFirstTab, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#D4D4D4"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <TextBlock Text="User Data Dir"
                                       Foreground="#858585"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Width="420"
                                     Text="{Binding DevBrowserUserDataDir, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E1E1E"
                                     Foreground="#D4D4D4"
                                     BorderBrush="#3C3C3C"
                                     BorderThickness="1"
                                     Padding="6,3"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Profile"
                                       Foreground="#858585"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Width="160"
                                      IsEditable="True"
                                      ItemsSource="{Binding DevDetectedBrowserProfiles}"
                                      Text="{Binding DevBrowserProfileDirectory, UpdateSourceTrigger=PropertyChanged}"
                                      Background="#1E1E1E"
                                      Foreground="{StaticResource DropDownTextBrush}"
                                      BorderBrush="#3C3C3C"
                                      BorderThickness="1"
                                      Margin="0,0,8,0"/>
                            <Button Style="{StaticResource ToolbarButton}" Content="Detect Profiles" Click="DevCdp_DetectProfiles" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource ToolbarButton}" Content="Use Local Chrome Data" Click="DevCdp_UseLocalChromeData"/>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Chrome Tab"
                                       Foreground="#858585"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox x:Name="DevCdpTabsCombo"
                                      Width="760"
                                      ItemsSource="{Binding DevCdpTabs}"
                                      SelectedItem="{Binding DevSelectedCdpTab}"
                                      Background="#1E1E1E"
                                      Foreground="{StaticResource DropDownTextBrush}"
                                      BorderBrush="#3C3C3C"
                                      BorderThickness="1"/>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBlock Text="{Binding DevCdpStatusDisplay}"
                                   Foreground="#9CDCFE"
                                   FontFamily="Consolas"
                                   FontSize="12"/>
                    </Border>

                    <ListBox x:Name="DevCdpEventsList"
                             ItemsSource="{Binding DevCdpEvents}"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderBrush="#3C3C3C"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
