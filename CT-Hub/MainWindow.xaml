<Window x:Class="CTHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CTHub"
        Title="CT Hub"
        Height="780" Width="1100"
        MinHeight="500" MinWidth="700"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Shared DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3C3C3C"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#5C1A1A"/>
            <Setter Property="BorderBrush" Value="#8B2020"/>
        </Style>
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ── Status Bar ──────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#007ACC" Foreground="White"
                   FontFamily="Consolas" FontSize="12">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ClientCountText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding LastBroadcast}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Tab Control ─────────────────────────────────────────────────── -->
        <TabControl Background="#1E1E1E" BorderBrush="#3C3C3C"
                    Foreground="#D4D4D4">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#9CDCFE"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ── Chase Tactical ─────────────────────────────────────────── -->
            <TabItem Header="Chase Tactical">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526" Band="1">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ChaseTactical_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ChaseTactical_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ChaseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search bin, label, qty, notes, id"/>
                    </Border>
                    <DataGrid x:Name="ChaseTacticalGrid"
                              ItemsSource="{Binding ChaseTacticalItems}"
                              CellEditEnding="ChaseTactical_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="ChaseTactical_Add"/>
                                <MenuItem Header="Delete Selected" Click="ChaseTactical_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Bin"
                                                    SelectedItemBinding="{Binding Bin, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{x:Static local:MainWindow.BinLocations}"
                                                    Width="130"/>
                            <DataGridComboBoxColumn Header="Class"
                                                    SelectedItemBinding="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{x:Static local:MainWindow.ClassNames}"
                                                    Width="220"/>
                            <DataGridComboBoxColumn Header="Letter"
                                                    SelectedItemBinding="{Binding ClassLetter, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{x:Static local:MainWindow.ClassLetters}"
                                                    Width="80"/>
                            <DataGridTextColumn Header="Class ID"    Binding="{Binding ClassId}"     Width="180" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Label"       Binding="{Binding Label}"       Width="200"/>
                            <DataGridTextColumn Header="Qty"         Binding="{Binding Qty}"         Width="80"/>
                            <DataGridTextColumn Header="Notes"       Binding="{Binding Notes}"       Width="*"/>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── Tough Hooks ───────────────────────────────────────────── -->
            <TabItem Header="Tough Hooks">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ToughHooks_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ToughHooks_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ToughHooksSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search bin, sku, description, qty, id"/>
                    </Border>
                    <DataGrid x:Name="ToughHooksGrid"
                              ItemsSource="{Binding ToughHookItems}"
                              CellEditEnding="ToughHooks_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="ToughHooks_Add"/>
                                <MenuItem Header="Delete Selected" Click="ToughHooks_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bin"         Binding="{Binding Bin}"         Width="120"/>
                            <DataGridTextColumn Header="SKU"         Binding="{Binding Sku}"         Width="140"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Qty"         Binding="{Binding Qty}"         Width="80"/>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── QR Mappings ───────────────────────────────────────────── -->
            <TabItem Header="QR Mappings">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="QrMappings_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="QrMappings_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding QrMappingsSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search QR value, classification, description, id"/>
                    </Border>
                    <DataGrid x:Name="QrMappingsGrid"
                              ItemsSource="{Binding QrMappingItems}"
                              CellEditEnding="QrMappings_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="QrMappings_Add"/>
                                <MenuItem Header="Delete Selected" Click="QrMappings_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="QR Value"      Binding="{Binding QrValue}"      Width="220"/>
                            <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="180"/>
                            <DataGridTextColumn Header="Description"   Binding="{Binding Description}"  Width="*"/>
                            <DataGridTextColumn Header="ID"            Binding="{Binding Id}"            Width="220" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── Shipping Supplys ─────────────────────────────────────── -->
            <TabItem Header="Shipping Supplys">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="＋  Add Row"
                                Click="ShippingSupplys_Add"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="✕  Delete"
                                Click="ShippingSupplys_Delete"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding ShippingSupplysSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search dimensions, bundle, single, id"/>
                    </Border>
                    <DataGrid x:Name="ShippingSupplysGrid"
                              ItemsSource="{Binding ShippingSupplysItems}"
                              CellEditEnding="ShippingSupplys_CellEditEnding">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Row" Click="ShippingSupplys_Add"/>
                                <MenuItem Header="Delete Selected" Click="ShippingSupplys_Delete"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dimensions" Binding="{Binding Dimensions}" Width="*"/>
                            <DataGridTextColumn Header="Bundle"     Binding="{Binding Bundle}"     Width="120"/>
                            <DataGridTextColumn Header="Single"     Binding="{Binding Single}"     Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── PDF Folder ─────────────────────────────────────────────── -->
            <TabItem Header="PDF Folder">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top" Background="#252526">
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="📂  Browse…"
                                Click="PdfFolder_Browse"/>
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="⚖  Scale Selected…"
                                Click="PdfScale_Click"/>
                        <Button Style="{StaticResource DeleteButton}"
                                Content="🗑  Delete Selected"
                                Click="PdfDelete_Click"/>
                        <Separator/>
                        <TextBlock x:Name="PdfFolderPathText"
                                   Text="No folder selected"
                                   Foreground="#9CDCFE"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                    </ToolBar>
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="8,6">
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding PdfSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search PDF filenames"/>
                    </Border>
                    <DataGrid x:Name="PdfFileGrid"
                              ItemsSource="{Binding PdfFileRows}"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Scale Selected..." Click="PdfScale_Click"/>
                                <MenuItem Header="Delete Selected" Click="PdfDelete_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PDF File" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Sales Orders" Binding="{Binding SalesOrders}" Width="220"/>
                            <DataGridTextColumn Header="Import Date/Time"
                                                Binding="{Binding ImportDateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                Width="190"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── Server ────────────────────────────────────────────────── -->
            <TabItem Header="Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <StackPanel Margin="24,20,24,24" MaxWidth="680">

                        <!-- HTTP SERVER ─────────────────────────────────── -->
                        <TextBlock Text="HTTP SERVER"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="Auto" MinHeight="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="#4EC9A0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Running" FontFamily="Consolas" FontSize="12" Foreground="#4EC9A0"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="HTTP / WebSocket Port"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="5050"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="WebSocket URL"
                                           VerticalAlignment="Top" Margin="0,6,0,0"
                                           FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HubUrl}"
                                           VerticalAlignment="Top" Margin="0,6,0,6"
                                           FontFamily="Consolas" FontSize="12" Foreground="#9CDCFE"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- LOCAL NETWORK ───────────────────────────────── -->
                        <TextBlock Text="LOCAL NETWORK"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Local IP(s)"
                                           VerticalAlignment="Top" Margin="0,6,0,0"
                                           FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalAddresses}"
                                           VerticalAlignment="Top" Margin="0,6,0,6"
                                           FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"
                                           TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Connected Clients"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientCountText}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Device"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastConnectedDevice}"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                            </Grid>
                        </Border>

                        <!-- UDP DISCOVERY BROADCAST ─────────────────────── -->
                        <TextBlock Text="UDP DISCOVERY BROADCAST"
                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#569CD6" Margin="0,0,0,8"/>
                        <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7" Fill="{Binding BroadcastDotColor}"
                                                 Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding BroadcastStatusText}"
                                                   Foreground="{Binding BroadcastTextColor}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Beacon Destination"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="255.255.255.255 : UDP 5051"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Beacon Interval"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#858585"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="3 seconds"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                                </Grid>

                                <Button Content="{Binding BroadcastButtonText}"
                                        Click="Broadcast_Toggle"
                                        Style="{StaticResource ToolbarButton}"
                                        HorizontalAlignment="Left"
                                        MinWidth="210"
                                        Margin="0,0,0,10"/>

                                <TextBlock Text="{Binding LastBeaconText}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#555"/>
                            </StackPanel>
                        </Border>

                        <!-- Firewall note ────────────────────────────────── -->
                        <Border Background="#1C1C1C" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="ⓘ  Firewall Note"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#858585" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Broadcasting uses UDP outbound only — no inbound firewall rule needed for discovery.  If TCP 5050 is blocked by Windows Firewall, run once as Administrator or add an inbound rule for port 5050."
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
