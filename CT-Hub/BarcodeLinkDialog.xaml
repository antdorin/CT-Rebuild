<Window x:Class="CTHub.BarcodeLinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Barcode Links"
        Width="620" SizeToContent="Height"
        MinHeight="260" MaxHeight="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="#252526"
        Foreground="#D4D4D4">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3A1A1A"/>
            <Setter Property="BorderBrush" Value="#6B2020"/>
            <Setter Property="Foreground" Value="#FF7777"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Barcode value header -->
        <TextBlock Text="Barcode value" Foreground="#858585" FontSize="11" Margin="0,0,0,2"/>
        <TextBlock x:Name="BarcodeValueText"
                   Foreground="White" FontFamily="Consolas" FontSize="14"
                   Margin="0,0,0,14"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Links list -->
        <TextBlock Text="Linked rows" Foreground="#858585" FontSize="11" Margin="0,0,0,4"/>

        <Border BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="4"
                Background="#1E1E1E" MinHeight="60" MaxHeight="380">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LinksPanel" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,3" Padding="8,6"
                                    Background="#2D2D30" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Table badge -->
                                    <Border Grid.Column="0"
                                            Background="#007ACC" CornerRadius="3"
                                            Padding="5,2" Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TableBadge}"
                                                   Foreground="White" FontSize="10"
                                                   FontFamily="Consolas"/>
                                    </Border>

                                    <!-- Label -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="#D4D4D4" FontSize="13"/>
                                        <TextBlock Text="{Binding SubLabel}"
                                                   Foreground="#666" FontSize="11"
                                                   Visibility="{Binding SubLabelVisibility}"/>
                                    </StackPanel>

                                    <!-- Remove button -->
                                    <Button Grid.Column="2"
                                            Style="{StaticResource DeleteButton}"
                                            Content="✕ Remove"
                                            Tag="{Binding LinkId}"
                                            Click="Remove_Click"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyText"
                   Text="No links yet. Use Add Link to associate rows."
                   Foreground="#555" FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource ActionButton}"
                    Content="＋  Add Link"
                    Click="AddLink_Click"
                    Margin="0,0,8,0"/>
            <Button Style="{StaticResource ActionButton}"
                    Content="Close"
                    IsCancel="True"
                    Click="Close_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
